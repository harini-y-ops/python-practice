# Find the largest and smallest number in a list without min() or max()
numbers = [1, 2, 3, 4, 5, 6, 7]
largest = numbers[0]
smallest = numbers[0]
for num in numbers:
    if num > largest:
        largest = num
    if num < smallest:
        smallest = num

print(f"Largest: {largest}")
print(f"Smallest: {smallest}")
